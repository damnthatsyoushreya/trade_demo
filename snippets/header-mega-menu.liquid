{% comment %}
  Renders a mega menu for the header (Trade theme).
  Place this file at: snippets/header-mega-menu.liquid
  Pure CSS hover — no JS flickering.
{% endcomment %}

<style>
.mega-nav__backdrop {
  display: none !important;
}
  .header__inline-menu {
    display: flex;
    align-items: center;
  }

  .mega-nav {
    display: flex;
    align-items: center;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .mega-nav__item {
    position: static;
  }

  .mega-nav__top-link {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.8rem 1.4rem;
    font-size: 1.4rem;
    font-weight: 500;
    text-decoration: none;
    color: currentColor;
    white-space: nowrap;
    background: none;
    border: none;
    font-family: inherit;
    letter-spacing: 0.03em;
    cursor: pointer;
    line-height: 1;
  }

  .mega-nav__top-link svg {
    width: 1rem;
    height: 1rem;
    transition: transform 0.2s ease;
    flex-shrink: 0;
  }

  /* Panel hidden by default */
  .mega-nav__panel {
    visibility: hidden;
    opacity: 0;
    pointer-events: none;
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    width: 100%;
    z-index: 200;
    background-color: rgb(var(--color-background));
    box-shadow: 0 8px 32px rgba(0,0,0,0.10);
    border-top: 1px solid rgba(var(--color-foreground), 0.08);
    padding: 3.2rem 0;
    transition: opacity 0.18s ease, visibility 0.18s ease;
  }

  /* Open on hover of the LI */
  .mega-nav__item:hover .mega-nav__panel {
    visibility: visible;
    opacity: 1;
    pointer-events: auto;
  }

  .mega-nav__item:hover .mega-nav__top-link svg {
    transform: rotate(180deg);
  }

  .mega-nav__inner {
    max-width: var(--page-width, 1200px);
    margin: 0 auto;
    padding: 0 3rem;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr));
    gap: 1.6rem 3.2rem;
  }

  .mega-nav__column {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .mega-nav__col-heading {
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    color: currentColor;
    padding-bottom: 0.8rem;
    border-bottom: 1px solid rgba(var(--color-foreground), 0.12);
    margin-bottom: 0.2rem;
    display: block;
    transition: opacity 0.15s;
  }
  .mega-nav__col-heading:hover { opacity: 0.6; }

  .mega-nav__sublist {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  .mega-nav__sublink {
    font-size: 1.4rem;
    text-decoration: none;
    color: currentColor;
    padding: 0.35rem 0;
    opacity: 0.72;
    display: block;
    transition: opacity 0.15s;
  }
  .mega-nav__sublink:hover,
  .mega-nav__sublink--active { opacity: 1; }

  /* Backdrop */
  .mega-nav__backdrop {
    visibility: hidden;
    opacity: 0;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.32);
    z-index: 199;
    transition: opacity 0.18s ease, visibility 0.18s ease;
    pointer-events: none;
  }

  .mega-nav:has(.mega-nav__item:hover) .mega-nav__backdrop {
    visibility: visible;
    opacity: 1;
  }

  @media screen and (max-width: 989px) {
    .header__inline-menu { display: none; }
  }
</style>

<nav class="header__inline-menu" aria-label="Main menu">
  <ul class="mega-nav" role="list">
    {%- for link in section.settings.menu.links -%}
      <li class="mega-nav__item">

        {%- if link.links != blank -%}

          <button class="mega-nav__top-link" aria-haspopup="true">
            <span{% if link.child_active %} class="header__active-menu-item"{% endif %}>
              {{- link.title | escape -}}
            </span>
            <span class="svg-wrapper">
              {{- 'icon-caret.svg' | inline_asset_content -}}
            </span>
          </button>

          <div class="mega-nav__panel" role="region" aria-label="{{ link.title | escape }} submenu">
            <div class="mega-nav__inner">
              {%- for childlink in link.links -%}
                <div class="mega-nav__column">
                  <a
                    href="{{ childlink.url }}"
                    class="mega-nav__col-heading{% if childlink.current %} mega-nav__col-heading--active{% endif %}"
                    {% if childlink.current %}aria-current="page"{% endif %}
                  >
                    {{- childlink.title | escape -}}
                  </a>

                  {%- if childlink.links != blank -%}
                    <ul class="mega-nav__sublist" role="list">
                      {%- for grandchildlink in childlink.links -%}
                        <li>
                          <a
                            href="{{ grandchildlink.url }}"
                            class="mega-nav__sublink{% if grandchildlink.current %} mega-nav__sublink--active{% endif %}"
                            {% if grandchildlink.current %}aria-current="page"{% endif %}
                          >
                            {{- grandchildlink.title | escape -}}
                          </a>
                        </li>
                      {%- endfor -%}
                    </ul>
                  {%- endif -%}
                </div>
              {%- endfor -%}
            </div>
          </div>

        {%- else -%}

          <a
            href="{{ link.url }}"
            class="mega-nav__top-link"
            {% if link.current %}aria-current="page"{% endif %}
          >
            <span{% if link.current %} class="header__active-menu-item"{% endif %}>
              {{- link.title | escape -}}
            </span>
          </a>

        {%- endif -%}
      </li>
    {%- endfor -%}

    <li class="mega-nav__backdrop" aria-hidden="true"></li>
  </ul>
</nav>
